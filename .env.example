# ── Côté serveur (Cloudflare Dashboard → Variables et secrets) ──
ADMIN_PASSWORD=              # Mot de passe admin Rochdi
RESEND_API_KEY=              # Clé API Resend (re_...)
WEBHOOK_SECRET=              # Secret partagé pour les webhooks clients
NOTIFICATION_EMAIL=          # Email de Rochdi pour les notifications globales
FCM_SERVER_KEY=              # Firebase Cloud Messaging server key (push notifications)
ALLOWED_ORIGINS=             # Origines CORS (séparées par virgules, ex: https://crm.intralys.com,capacitor://localhost)

# ── Dev bypass (optionnel — UNIQUEMENT en local, JAMAIS en prod) ──
# DEV_BYPASS_AUTH=true        # Backend : bypass rate limit + password check (.dev.vars)
# VITE_DEV_BYPASS_AUTH=true   # Frontend : fake login response sans appeler le worker (.env.local)

# ── Côté client (.env.local) ──
# VITE_API_URL=              # URL API absolue pour Capacitor natif (ex: https://crm.intralys.com)

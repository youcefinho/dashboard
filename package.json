{
  "name": "intralys-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev src/worker.ts --local --port 8787",
    "db:init": "wrangler d1 execute intralys-crm --local --file=schema.sql && wrangler d1 execute intralys-crm --local --file=seed.sql",
    "db:migrate": "wrangler d1 execute intralys-crm --local --file=migration-phase1.sql",
    "db:migrate:phase2": "wrangler d1 execute intralys-crm --local --file=migration-phase2.sql",
    "db:migrate:phase3": "wrangler d1 execute intralys-crm --local --file=migration-phase3.sql",
    "db:migrate:phase4": "wrangler d1 execute intralys-crm --local --file=migration-phase4.sql",
    "db:migrate:phase5": "wrangler d1 execute intralys-crm --local --file=migration-phase5.sql",
    "db:migrate:phase8": "wrangler d1 execute intralys-crm --local --file=migration-phase8.sql",
    "db:migrate:phase9": "wrangler d1 execute intralys-crm --local --file=migration-phase9.sql",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "wrangler": "^4.86.0"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.168.25",
    "recharts": "^3.8.1",
    "resend": "^6.12.2",
    "zod": "^4.4.3"
  }
}
